# Server Configuration
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/adx_platform
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Secret
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=24h

# Ad Exchange Settings
MIN_BID_PRICE=0.01
MAX_BID_PRICE=100.00
AUCTION_TIMEOUT=120
DEFAULT_CURRENCY=USD

# External Services (Optional)
ANALYTICS_API_KEY=
PAYMENT_GATEWAY_KEY=
