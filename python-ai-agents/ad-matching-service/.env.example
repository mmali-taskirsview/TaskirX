# Server Configuration
PORT=6002
HOST=0.0.0.0
ENV=development
DEBUG=true

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=3
REDIS_PASSWORD=

# Matching Configuration
MAX_RECOMMENDATIONS=10
MIN_SIMILARITY_SCORE=0.3
CONTENT_WEIGHT=0.4
COLLABORATIVE_WEIGHT=0.6

# Performance
MAX_WORKERS=4
REQUEST_TIMEOUT=50
CACHE_TTL=600

# Monitoring
ENABLE_METRICS=true
LOG_LEVEL=INFO

# External Services
NESTJS_API_URL=http://localhost:4000
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=taskirx_analytics
