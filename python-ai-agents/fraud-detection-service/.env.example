# Server Configuration
PORT=6001
HOST=0.0.0.0
ENV=development
DEBUG=true

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=2
REDIS_PASSWORD=

# Model Configuration
MODEL_PATH=./models/fraud_detector.pkl
MODEL_THRESHOLD=0.7
FEATURE_SCALER_PATH=./models/scaler.pkl

# Performance
MAX_WORKERS=4
REQUEST_TIMEOUT=100
CACHE_TTL=300

# Monitoring
ENABLE_METRICS=true
LOG_LEVEL=INFO

# External Services
NESTJS_API_URL=http://localhost:4000
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=taskirx_analytics
