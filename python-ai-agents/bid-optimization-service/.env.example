# Server Configuration
PORT=6003
HOST=0.0.0.0
ENV=development
DEBUG=true

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=4
REDIS_PASSWORD=

# Optimization Configuration
EXPLORATION_RATE=0.1
LEARNING_RATE=0.01
DISCOUNT_FACTOR=0.95
MIN_BID_MULTIPLIER=0.5
MAX_BID_MULTIPLIER=2.0

# Budget Pacing
PACING_STRATEGY=even
SAFETY_MARGIN=0.1

# Performance
MAX_WORKERS=4
REQUEST_TIMEOUT=50
CACHE_TTL=300

# Monitoring
ENABLE_METRICS=true
LOG_LEVEL=INFO

# External Services
NESTJS_API_URL=http://localhost:4000
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=taskirx_analytics
