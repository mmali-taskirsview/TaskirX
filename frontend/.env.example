# Frontend Environment Variables
# Copy this file to .env and fill in your values

# API Configuration
VITE_API_URL=http://localhost:3000
VITE_API_TIMEOUT=30000

# Stripe Configuration
VITE_STRIPE_PUBLIC_KEY=pk_test_51234567890abcdefghijklmnop

# PayPal Configuration
VITE_PAYPAL_CLIENT_ID=AaBbCcDdEeFfGgHhIiJjKkLlMmNnOoPpQqRrSsTtUuVvWwXxYyZz

# Application Settings
VITE_APP_ENV=development
VITE_APP_DEBUG=true

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true

# Payment Configuration
VITE_MIN_PAYMENT_AMOUNT=100
VITE_MAX_PAYMENT_AMOUNT=999999
VITE_SUPPORTED_CURRENCIES=USD,EUR,GBP

# CORS Settings
VITE_CORS_ORIGIN=http://localhost:3000
