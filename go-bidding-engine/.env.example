# Server Configuration
PORT=5000
GRPC_PORT=5001
ENV=development

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_POOL_SIZE=100

# NestJS Backend
BACKEND_API_URL=http://localhost:4000

# Performance Tuning
MAX_CONCURRENT_BIDS=10000
BID_TIMEOUT_MS=50
CACHE_TTL_SECONDS=300

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090
