{
  "name": "taskir-x",
  "version": "2.1.0",
  "description": "TaskirX - AI-Powered Ad Exchange Platform with Machine Learning",
  "main": "nestjs-backend/src/main.ts",
  "scripts": {
    "start": "cd nestjs-backend && npm run start",
    "dev": "cd nestjs-backend && npm run start:dev",
    "test": "cd nestjs-backend && npm run test",
    "test:watch": "cd nestjs-backend && npm run test:watch",
    "lint": "cd nestjs-backend && npm run lint",
    "start:dashboard": "cd next-dashboard && npm run dev",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:seed": "cd nestjs-backend && npm run seed"
  },
  "keywords": [
    "adx",
    "rtb",
    "ad-exchange",
    "programmatic-advertising",
    "openrtb",
    "supply-side-platform",
    "demand-side-platform"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
